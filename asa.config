# ASA Blockchain - Development Configuration
# Baserat på gstack + GSD-2

[project]
name = "asa-blockchain"
version = "0.1.0"
description = "AI-Driven L1 + L2 Blockchain with Nordic Identity"

[development]
# Primary model for development
model = "claude-sonnet-4-20250514"

# Use gstack roles for all code reviews
roles = [
  "ceo",      # /plan-ceo-review
  "eng",      # /plan-eng-review  
  "design",   # /plan-design-review
  "review",   # /review
  "qa",       # /qa
  "security", # /security-audit
  "ship",     # /ship
]

[code Quality]
# Enforce on every commit
lint = true
test = true
format = true
clippy = true

# Security
security_scan = true
owasp = true

[deployment]
# Auto-deploy to testnet
testnet = "auto"
mainnet = "manual"

[tokens]
# Track development costs
track_usage = true
budget_alert = 1000

[agents]
# ASA-specific agent roles
asa_neural_nexus = "enabled"
asa_mev_protector = "enabled"
asa_governance = "enabled"
asa_analytics = "enabled"